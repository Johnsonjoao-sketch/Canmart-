{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and financial data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "phone": { "type": "string" },
        "balance": { "type": "number" },
        "totalDeposited": { "type": "number" },
        "totalWithdrawn": { "type": "number" },
        "referrerId": { "type": "string" },
        "referralCode": { "type": "string" },
        "bankData": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "number": { "type": "string" },
            "bank": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "phone", "balance"]
    },
    "Investment": {
      "title": "Investment",
      "description": "Active investment plan for a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "planId": { "type": "string" },
        "amount": { "type": "number" },
        "dailyReturn": { "type": "number" },
        "startDate": { "type": "string", "format": "date-time" },
        "expiryDate": { "type": "string", "format": "date-time" },
        "lastCreditDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["active", "expired"] }
      }
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Deposit or withdrawal transaction",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["deposit", "withdrawal"] },
        "amount": { "type": "number" },
        "method": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "proofImageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User collection"
    },
    "/investments/{investmentId}": {
      "schema": "Investment",
      "description": "Investments collection"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Transactions collection"
    }
  }
}
